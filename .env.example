# Kiwoom connection template
# Copy to .env and fill sensitive values locally (do NOT paste secrets into chat).

# Kiwoom REST / OAuth
KIWOOM_API_BASE=https://api.kiwoom.example/
KIWOOM_TOKEN_URL=https://auth.kiwoom.example/oauth/token
KIWOOM_CLIENT_ID=your_client_id_here
KIWOOM_CLIENT_SECRET=your_client_secret_here
KIWOOM_TOKEN_STORE=kiwoom_token_store.json
KIWOOM_TOKEN_SAFETY_MARGIN=60

# Kiwoom WebSocket / Realtime
KIWOOM_WS_URL=wss://realtime.kiwoom.example/ws  # or ws://localhost:8765 for mock
KIWOOM_WS_TRNM=your_trnm_if_needed
TRADING_ENV=mock  # or live

# Account / trading defaults
ACCOUNT_NO=12345678
ORDER_TIF=IOC
DEFAULT_TICK_OFFSET=0

# Local settings
VENV_PYTHON=.venv/bin/python
LOG_LEVEL=INFO
